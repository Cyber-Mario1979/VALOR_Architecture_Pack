{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/staged_task_set.schema.json",
  "title": "Staged Task Set Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["action_type", "wp_id", "staged_task_set_id", "state", "tasks", "provenance_stamps", "validation_result"],
  "properties": {
    "action_type": {"type": "string", "const": "WP_STAGE_TASKS"},
    "wp_id": {"type": "string", "minLength": 1},
    "staged_task_set_id": {"type": "string", "minLength": 1},
    "state": {"type": "string", "const": "STAGED"},
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["task_id", "wp_id", "name", "task_type", "phase", "status"],
        "properties": {
          "task_id": {"type": "string", "minLength": 1},
          "wp_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "task_type": {"type": "string", "enum": ["AUTHORING", "REVIEW", "APPROVAL", "EXECUTION", "REPORTING", "VENDOR_WAIT", "PROCUREMENT_WAIT", "LEAD_TIME"]},
          "phase": {"type": "string", "minLength": 1},
          "status": {"type": "string", "const": "STAGED"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "duration_ref": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "preset_ref": {"type": "object", "additionalProperties": true},
    "source_task_pool_ref": {"type": "object", "additionalProperties": true},
    "provenance_stamps": {"type": "object", "minProperties": 1, "additionalProperties": true},
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "errors", "warnings"],
      "properties": {
        "ok": {"type": "boolean"},
        "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "warnings": {"type": "array", "items": {"type": "object", "additionalProperties": true}}
      }
    }
  }
}
