{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_external_references.schema.json",
  "title": "KS External References Register",
  "type": "object",
  "additionalProperties": true,
  "required": ["reference_register_id", "version", "owner", "effective_date", "source_checked_date", "review_cycle_months", "next_review_due", "expiry_date", "status", "review_required", "expired_behavior", "references"],
  "properties": {
    "reference_register_id": {"type": "string"},
    "version": {"type": "string"},
    "owner": {"type": "string"},
    "effective_date": {"type": "string"},
    "source_checked_date": {"type": "string"},
    "review_cycle_months": {"type": "integer", "minimum": 1},
    "next_review_due": {"type": "string"},
    "expiry_date": {"type": "string"},
    "status": {"enum": ["ACTIVE", "DUE_FOR_REVIEW", "EXPIRED", "SUPERSEDED", "BLOCKED", "PRE_FREEZE_USER_REVIEW_REQUIRED"]},
    "review_required": {"type": "boolean"},
    "expired_behavior": {"type": "string"},
    "references": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["source_id", "title", "publisher_or_authority", "version_or_edition", "document_date", "source_type", "access_classification", "excerpt_policy", "status", "review_required", "anchors"], "additionalProperties": true}}
  }
}
