{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/plan_proposal.schema.json",
  "title": "Plan Proposal Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["action_type", "plan_proposal_id", "wp_id", "state", "apply_required", "schedule", "calendar_logic_ref", "planning_basis", "provenance_stamps", "validation_result"],
  "properties": {
    "action_type": {"type": "string", "const": "PLAN_GENERATE_PROPOSAL"},
    "plan_proposal_id": {"type": "string", "minLength": 1},
    "wp_id": {"type": "string", "minLength": 1},
    "state": {"type": "string", "const": "PROPOSED"},
    "apply_required": {"type": "boolean", "const": true},
    "planning_basis": {"type": "string", "enum": ["PROFILE_BASED", "USER_DRIVEN_NO_PROFILE"]},
    "calendar_logic_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": ["calendar_id", "calendar_version", "canonical_calendar_version"]
    },
    "profile_ref": {"type": ["object", "null"], "additionalProperties": true},
    "schedule": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["task_id", "proposed_start_date", "proposed_finish_date", "duration_value", "duration_unit"],
        "properties": {
          "task_id": {"type": "string", "minLength": 1},
          "proposed_start_date": {"type": "string"},
          "proposed_finish_date": {"type": "string"},
          "duration_value": {"type": "number"},
          "duration_unit": {"type": "string", "enum": ["WORKING_DAYS", "CALENDAR_DAYS", "CALENDAR_WEEKS", "CALENDAR_MONTHS"]},
          "depends_on": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "provenance_stamps": {"type": "object", "minProperties": 1, "additionalProperties": true},
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "errors", "warnings"],
      "properties": {
        "ok": {"type": "boolean"},
        "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "warnings": {"type": "array", "items": {"type": "object", "additionalProperties": true}}
      }
    }
  }
}
