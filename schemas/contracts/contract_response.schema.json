{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/contract_response.schema.json",
  "title": "Contract Response Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "contract_version",
    "action_id",
    "ok",
    "result",
    "error"
  ],
  "properties": {
    "contract": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "result": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "subcode": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "entity": {
          "type": "string"
        },
        "remediation": {
          "type": "string"
        }
      }
    }
  }
}
