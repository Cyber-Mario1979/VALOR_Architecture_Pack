{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/contract_response.schema.json",
  "title": "Contract Response Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "contract_version",
    "action_id",
    "ok",
    "result",
    "error"
  ],
  "properties": {
    "contract": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "result": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "subcode": {
          "type": "string"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "entity": {
          "type": "string"
        },
        "remediation": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "ok": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "error": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ok": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "result": {
            "type": "null"
          },
          "error": {
            "type": "object"
          }
        }
      }
    }
  ]
}
