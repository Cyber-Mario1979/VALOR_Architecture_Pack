{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_source_mapping.schema.json",
  "title": "KS Source to Internal Requirement Mapping",
  "type": "object",
  "additionalProperties": true,
  "required": ["mapping_id", "version", "owner", "effective_date", "source_checked_date", "review_cycle_months", "next_review_due", "expiry_date", "status", "review_required", "expired_behavior", "mappings"],
  "properties": {
    "mapping_id": {"type": "string"},
    "version": {"type": "string"},
    "owner": {"type": "string"},
    "effective_date": {"type": "string"},
    "source_checked_date": {"type": "string"},
    "review_cycle_months": {"type": "integer", "minimum": 1},
    "next_review_due": {"type": "string"},
    "expiry_date": {"type": "string"},
    "status": {"enum": ["ACTIVE", "DUE_FOR_REVIEW", "EXPIRED", "SUPERSEDED", "BLOCKED", "PRE_FREEZE_USER_REVIEW_REQUIRED"]},
    "review_required": {"type": "boolean"},
    "expired_behavior": {"type": "string"},
    "mappings": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["mapping_ref", "internal_requirement_id", "source_anchor_refs", "mapping_basis", "status"], "additionalProperties": true}}
  }
}
