{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_bundle_validation.schema.json",
  "title": "KS Bundle Validation",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle_id", "version", "ok", "status", "checks", "blocked_behavior"],
  "properties": {
    "bundle_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "ok": {"type": "boolean"},
    "status": {"type": "string", "enum": ["ACTIVE", "DUE_FOR_REVIEW", "EXPIRED", "SUPERSEDED", "BLOCKED", "PRE_FREEZE_USER_REVIEW_REQUIRED"]},
    "checks": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["check_id", "ok", "severity"], "additionalProperties": true}},
    "errors": {"type": "array", "items": {"type": "object", "required": ["code", "message"], "additionalProperties": true}},
    "blocked_behavior": {"type": "string", "minLength": 1}
  }
}
