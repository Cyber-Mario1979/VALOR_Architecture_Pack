{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_template.schema.json",
  "title": "Knowledge Store Template",
  "type": "object",
  "additionalProperties": true,
  "required": ["template_id", "version", "doc_type", "owner", "effective_date", "source_checked_date", "review_cycle_months", "next_review_due", "expiry_date", "status", "review_required", "expired_behavior", "required_inputs", "required_stamps", "anchor_policy", "sections", "missing_or_expired_behavior"],
  "properties": {
    "template_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "doc_type": {"enum": ["VMP", "URS", "RA", "RTM", "DQ", "IQ", "OQ", "PQ", "VSR", "REPORT"]},
    "owner": {"type": "string", "minLength": 1},
    "effective_date": {"type": "string", "minLength": 1},
    "source_checked_date": {"type": "string", "minLength": 1},
    "review_cycle_months": {"type": "integer", "minimum": 1},
    "next_review_due": {"type": "string", "minLength": 1},
    "expiry_date": {"type": "string", "minLength": 1},
    "status": {"enum": ["ACTIVE", "DUE_FOR_REVIEW", "EXPIRED", "SUPERSEDED", "BLOCKED", "PRE_FREEZE_USER_REVIEW_REQUIRED"]},
    "review_required": {"type": "boolean"},
    "expired_behavior": {"type": "string", "minLength": 1},
    "required_inputs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "required_stamps": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "anchor_policy": {"type": "object"},
    "sections": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "missing_or_expired_behavior": {"type": "string", "minLength": 1}
  }
}
