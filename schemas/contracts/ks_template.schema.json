{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_template.schema.json",
  "title": "Knowledge Store Template",
  "type": "object",
  "additionalProperties": true,
  "required": ["template_id", "version", "doc_type", "owner", "effective_date", "source_checked_date", "review_cycle_months", "next_review_due", "expiry_date", "status", "required_inputs", "required_stamps", "anchor_policy", "sections", "missing_or_expired_behavior"],
  "properties": {
    "template_id": {"type": "string"},
    "version": {"type": "string"},
    "doc_type": {"type": "string"},
    "owner": {"type": "string"},
    "effective_date": {"type": "string"},
    "source_checked_date": {"type": "string"},
    "review_cycle_months": {"type": "integer", "minimum": 1},
    "next_review_due": {"type": "string"},
    "expiry_date": {"type": "string"},
    "status": {"enum": ["TESTING_ONLY", "PRE_FREEZE_USER_REVIEW_REQUIRED", "ACTIVE", "DUE_FOR_REVIEW", "EXPIRED", "SUPERSEDED", "BLOCKED"]},
    "usage_classification": {"type": "string"},
    "testing_use_allowed": {"type": "boolean"},
    "regulated_output_allowed": {"type": "boolean"},
    "testing_only_stamp_required": {"type": "boolean"},
    "approval_status": {"type": "string"},
    "source_metadata_acceptance_status": {"type": "string"},
    "testing_expired_behavior": {"type": "string"},
    "regulated_expired_behavior": {"type": "string"},
    "required_inputs": {"type": "array", "minItems": 1},
    "required_stamps": {"type": "array", "minItems": 1},
    "anchor_policy": {"type": "object"},
    "sections": {"type": "array", "minItems": 1},
    "missing_or_expired_behavior": {"type": "string"}
  }
}
