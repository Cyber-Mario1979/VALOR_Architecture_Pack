{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/report_request.schema.json",
  "title": "VALOR RPT Status Report Request Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "target_scope",
    "wp_ids",
    "source_snapshot_refs",
    "stamps",
    "validation_mode"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "WORK_PACKAGE_STATUS_REPORT"},
    "target_scope": {"type": "string", "enum": ["SINGLE_WP", "SELECTED_WP_SET"]},
    "wp_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "source_snapshot_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["wp_id", "snapshot_ref", "snapshot_hash"],
        "properties": {
          "wp_id": {"type": "string", "minLength": 1},
          "snapshot_ref": {"type": "string", "minLength": 1},
          "snapshot_hash": {"type": "string", "minLength": 1}
        }
      }
    },
    "stamps": {"type": "object", "additionalProperties": true},
    "validation_mode": {"type": "string", "const": "STRICT"},
    "title": {"type": "string"},
    "include_sections": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "COVER_PAGE",
          "EXECUTIVE_SUMMARY",
          "WORK_PACKAGE_OVERVIEW",
          "TASK_STATUS_SUMMARY",
          "SCHEDULE_SUMMARY",
          "RISKS_ISSUES_EXCEPTIONS",
          "TRACEABILITY_GOVERNANCE",
          "RECOMMENDATIONS_NEXT_ACTIONS",
          "APPENDIX"
        ]
      }
    },
    "output_format": {"type": "string", "enum": ["PDF", "REPORT_SOURCE"]},
    "options": {"type": "object", "additionalProperties": true}
  }
}
