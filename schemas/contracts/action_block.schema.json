{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/action_block.schema.json",
  "title": "VALOR Action Block",
  "type": "object",
  "additionalProperties": true,
  "oneOf": [
    {
      "title": "Canonical action block",
      "required": [
        "action_type",
        "contract",
        "version",
        "purpose",
        "allowed_modes",
        "side_effect_class",
        "confirmation_required"
      ],
      "not": {
        "required": ["alias_id"]
      }
    },
    {
      "title": "Alias action block",
      "required": [
        "alias_id",
        "canonical_action_type",
        "contract",
        "version",
        "purpose",
        "allowed_modes",
        "side_effect_class",
        "confirmation_required"
      ],
      "not": {
        "required": ["action_type"]
      }
    }
  ],
  "properties": {
    "action_type": {
      "type": "string",
      "enum": [
        "WP_GET",
        "WP_CREATE",
        "WP_STAGE_TASKS",
        "WP_COMMIT_STAGED_TASKS",
        "WP_UPDATE_TASK_FIELDS",
        "WP_APPLY_PLAN_PROPOSAL",
        "WP_BIND_PRESET_CONTEXT",
        "WP_SET_PLANNING_BASIS",
        "WP_SET_TASK_DURATION_OVERRIDES",
        "WP_RECORD_CONFIRMATION",
        "PLAN_GENERATE_PROPOSAL",
        "PLAN_VALIDATE_PROPOSAL",
        "DOC_GENERATE_DRAFT",
        "DOC_FINALIZE_ARTIFACT",
        "RPT_GENERATE_STATUS_REPORT",
        "RPT_VALIDATE_REPORT_INPUTS",
        "RPT_GENERATE_WORKBOOK_EXPORT",
        "RPT_VALIDATE_WORKBOOK_EXPORT",
        "RPT_GENERATE_GANTT_CHART",
        "RPT_VALIDATE_GANTT_INPUTS",
        "RPT_VALIDATE_STAMPS",
        "RPT_LIST_ARTIFACTS",
        "RPT_GET_ARTIFACT",
        "KS_LIST_STANDARDS",
        "KS_READ_STANDARD",
        "KS_LIST_TEMPLATES",
        "KS_READ_TEMPLATE",
        "KS_LIST_BUNDLES",
        "KS_READ_BUNDLE",
        "KS_LIST_ANCHORS",
        "KS_RESOLVE_CITATION",
        "KS_VALIDATE_CITATION_SET",
        "KS_VALIDATE_TEMPLATE_REQUIREMENTS",
        "KS_VALIDATE_SOURCE_MAPPING",
        "KS_VALIDATE_BUNDLE_INTEGRITY",
        "PS_LIST_PRESETS",
        "PS_READ_PRESET",
        "PS_RESOLVE_PRESET",
        "PS_VALIDATE_BINDINGS"
      ]
    },
    "alias_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_action_type": {
      "type": "string",
      "enum": [
        "RPT_GENERATE_STATUS_REPORT"
      ]
    },
    "public_command_aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contract": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "allowed_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "M1",
          "M2"
        ]
      }
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "READ_ONLY",
        "VALIDATE_ONLY",
        "STAGE_ONLY",
        "MUTATES_TRUTH",
        "GENERATES_ARTIFACT"
      ]
    },
    "idempotent": {
      "type": "boolean"
    },
    "confirmation_required": {
      "type": "boolean"
    },
    "status": {
      "type": "string"
    },
    "required_payload_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "optional_payload_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "result_schema_ref": {
      "type": "string"
    },
    "request_schema_ref": {
      "type": "string"
    },
    "target_fields": {
      "type": "object",
      "additionalProperties": true
    },
    "target_scope": {
      "type": "object",
      "additionalProperties": true
    },
    "projection_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "validation_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    }
  }
}
