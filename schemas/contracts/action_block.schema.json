{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/action_block.schema.json",
  "title": "VALOR Action Block",
  "type": "object",
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "action_type"
      ]
    },
    {
      "required": [
        "alias_id",
        "canonical_action_type"
      ]
    }
  ],
  "required": [
    "contract",
    "version",
    "purpose",
    "allowed_modes",
    "side_effect_class",
    "confirmation_required"
  ],
  "properties": {
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "alias_id": {
      "type": "string",
      "minLength": 1
    },
    "canonical_action_type": {
      "type": "string",
      "minLength": 1
    },
    "public_command_aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contract": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "allowed_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "M1",
          "M2"
        ]
      }
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "READ_ONLY",
        "VALIDATE_ONLY",
        "STAGE_ONLY",
        "MUTATES_TRUTH",
        "GENERATES_ARTIFACT"
      ]
    },
    "idempotent": {
      "type": "boolean"
    },
    "confirmation_required": {
      "type": "boolean"
    },
    "required_payload_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "optional_payload_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "result_schema_ref": {
      "type": "string"
    },
    "request_schema_ref": {
      "type": "string"
    },
    "target_scope": {
      "type": "object",
      "additionalProperties": true
    },
    "projection_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "validation_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
