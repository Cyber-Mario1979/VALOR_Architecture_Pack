{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_standards_list.schema.json",
  "title": "KS Standards List",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "standards"],
  "properties": {
    "status": {"type": "string", "enum": ["TESTING_ONLY", "PRE_FREEZE_USER_REVIEW_REQUIRED", "ACTIVE", "DUE_FOR_REVIEW", "EXPIRED", "SUPERSEDED", "BLOCKED"]},
    "standards": {"type": "array", "items": {"type": "object", "required": ["standard_id", "version", "status", "expiry_date"], "additionalProperties": true}}
  }
}
