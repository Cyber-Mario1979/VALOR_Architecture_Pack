{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_anchors_list.schema.json",
  "title": "KS Anchors List",
  "type": "object",
  "additionalProperties": false,
  "required": ["asset_type", "asset_id", "asset_version", "anchors"],
  "properties": {
    "asset_type": {"type": "string", "enum": ["standard", "template", "external_reference"]},
    "asset_id": {"type": "string", "minLength": 1},
    "asset_version": {"type": "string", "minLength": 1},
    "anchors": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["anchor_id", "anchor_title", "anchor_type", "locator", "excerpt_allowed"], "properties": {"anchor_id": {"type": "string"}, "anchor_title": {"type": "string"}, "anchor_type": {"type": "string"}, "locator": {"type": "string"}, "excerpt_allowed": {"type": "boolean"}}, "additionalProperties": true}}
  }
}
