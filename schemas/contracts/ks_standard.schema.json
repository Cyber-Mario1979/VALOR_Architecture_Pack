{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_standard.schema.json",
  "title": "Knowledge Store Internal Standard",
  "type": "object",
  "additionalProperties": true,
  "required": ["standard_id", "version", "title", "owner", "effective_date", "source_checked_date", "review_cycle_months", "next_review_due", "expiry_date", "status", "access_classification", "excerpt_policy", "requirements"],
  "properties": {
    "standard_id": {"type": "string"},
    "version": {"type": "string"},
    "title": {"type": "string"},
    "owner": {"type": "string"},
    "effective_date": {"type": "string"},
    "source_checked_date": {"type": "string"},
    "review_cycle_months": {"type": "integer", "minimum": 1},
    "next_review_due": {"type": "string"},
    "expiry_date": {"type": "string"},
    "status": {"enum": ["TESTING_ONLY", "PRE_FREEZE_USER_REVIEW_REQUIRED", "ACTIVE", "DUE_FOR_REVIEW", "EXPIRED", "SUPERSEDED", "BLOCKED"]},
    "usage_classification": {"type": "string"},
    "testing_use_allowed": {"type": "boolean"},
    "regulated_output_allowed": {"type": "boolean"},
    "testing_only_stamp_required": {"type": "boolean"},
    "approval_status": {"type": "string"},
    "source_metadata_acceptance_status": {"type": "string"},
    "testing_expired_behavior": {"type": "string"},
    "regulated_expired_behavior": {"type": "string"},
    "access_classification": {"type": "string"},
    "excerpt_policy": {"type": "string"},
    "requirements": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["requirement_id", "title", "internal_requirement_statement", "source_refs", "source_anchor_refs", "source_to_internal_mapping_ref", "failure_behavior", "lifecycle_status"], "additionalProperties": true}}
  }
}
