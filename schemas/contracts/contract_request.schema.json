{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/contract_request.schema.json",
  "title": "Contract Request Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "contract_version",
    "action_id",
    "action_type",
    "mode",
    "payload",
    "context"
  ],
  "properties": {
    "contract": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "DESIGN",
        "EXECUTION"
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "role": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": true
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "options": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "timestamp_utc"
      ],
      "properties": {
        "timestamp_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
