{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/workbook_export_request.schema.json",
  "title": "VALOR RPT Workbook Export Request Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "target_scope",
    "wp_ids",
    "source_snapshot_refs",
    "workbook_template_id",
    "stamps",
    "validation_mode"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "WORK_PACKAGE_WORKBOOK_EXPORT"},
    "target_scope": {"type": "string", "enum": ["SINGLE_WP", "SELECTED_WP_SET"]},
    "wp_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "source_snapshot_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["wp_id", "snapshot_ref", "snapshot_hash"],
        "properties": {
          "wp_id": {"type": "string", "minLength": 1},
          "snapshot_ref": {"type": "string", "minLength": 1},
          "snapshot_hash": {"type": "string", "minLength": 1}
        }
      }
    },
    "workbook_template_id": {"type": "string", "const": "TPL-RPT-WP-WORKBOOK-EXPORT-v1.0.1"},
    "stamps": {"type": "object", "additionalProperties": true},
    "validation_mode": {"type": "string", "const": "STRICT"},
    "workbook_options": {"type": "object", "additionalProperties": true},
    "include_charts": {"type": "boolean"}
  }
}
