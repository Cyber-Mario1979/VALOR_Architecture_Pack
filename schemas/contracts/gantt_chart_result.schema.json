{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/gantt_chart_result.schema.json",
  "title": "VALOR RPT Gantt Chart Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_metadata",
    "gantt_type",
    "gantt_format",
    "timeline",
    "layout_rules",
    "required_sheets",
    "sheet_validation"
  ],
  "properties": {
    "artifact_metadata": {"$ref": "../objects/rpt_artifact_metadata_schema.json"},
    "gantt_type": {"type": "string", "const": "WORK_PACKAGE_GANTT_CHART"},
    "gantt_format": {"type": "string", "const": "XLSX"},
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["granularity", "timeline_start", "timeline_end"],
      "properties": {
        "granularity": {"type": "string", "enum": ["DAY", "WEEK", "MONTH"]},
        "timeline_start": {"type": "string", "format": "date"},
        "timeline_end": {"type": "string", "format": "date"}
      }
    },
    "layout_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeline_coloring", "character_bars_inside_cells"],
      "properties": {
        "timeline_coloring": {"type": "string", "const": "FULL_CELL_FILL"},
        "character_bars_inside_cells": {"type": "boolean", "const": false},
        "selected_wp_set_grouping": {"type": "string", "enum": ["GROUP_BY_WP"]}
      }
    },
    "required_sheets": {
      "type": "array",
      "minItems": 3,
      "items": {"type": "string"},
      "contains": {"const": "Gantt"}
    },
    "sheet_validation": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sheet_name", "required", "present", "errors", "warnings"],
        "properties": {
          "sheet_name": {"type": "string"},
          "required": {"type": "boolean"},
          "present": {"type": "boolean"},
          "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
          "warnings": {"type": "array", "items": {"type": "object", "additionalProperties": true}}
        }
      }
    },
    "gantt_schema_ref": {"type": "string", "const": "schemas/objects/gantt_chart_schema.json"}
  }
}
