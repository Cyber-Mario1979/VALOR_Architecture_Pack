{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/ks_bundle.schema.json",
  "title": "Knowledge Store Bundle",
  "type": "object",
  "additionalProperties": true,
  "required": ["bundle_id", "version", "name", "owner", "effective_date", "source_checked_date", "review_cycle_months", "next_review_due", "expiry_date", "status", "review_required", "expired_behavior", "included_internal_standards", "blocked_state_rules"],
  "properties": {
    "bundle_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "effective_date": {"type": "string", "minLength": 1},
    "source_checked_date": {"type": "string", "minLength": 1},
    "review_cycle_months": {"type": "integer", "minimum": 1},
    "next_review_due": {"type": "string", "minLength": 1},
    "expiry_date": {"type": "string", "minLength": 1},
    "status": {"enum": ["ACTIVE", "DUE_FOR_REVIEW", "EXPIRED", "SUPERSEDED", "BLOCKED", "PRE_FREEZE_USER_REVIEW_REQUIRED"]},
    "review_required": {"type": "boolean"},
    "expired_behavior": {"type": "string", "minLength": 1},
    "applicability": {"type": "object"},
    "included_internal_standards": {"type": "array", "minItems": 1},
    "included_external_references": {"type": "array", "items": {"type": "string"}},
    "included_templates": {"type": "array"},
    "conditional_addon_triggers": {"type": "array"},
    "default_citation_set": {"type": "array"},
    "blocked_state_rules": {"type": "object", "minProperties": 1}
  }
}
