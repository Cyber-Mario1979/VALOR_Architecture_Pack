{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/report_result.schema.json",
  "title": "VALOR RPT Status Report Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_metadata",
    "report_type",
    "report_sections",
    "rendered_report_source"
  ],
  "properties": {
    "artifact_metadata": {"$ref": "../objects/rpt_artifact_metadata_schema.json"},
    "report_type": {"type": "string", "const": "WORK_PACKAGE_STATUS_REPORT"},
    "report_sections": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_id", "title", "required"],
        "properties": {
          "section_id": {
            "type": "string",
            "enum": [
              "COVER_PAGE",
              "EXECUTIVE_SUMMARY",
              "WORK_PACKAGE_OVERVIEW",
              "TASK_STATUS_SUMMARY",
              "SCHEDULE_SUMMARY",
              "RISKS_ISSUES_EXCEPTIONS",
              "TRACEABILITY_GOVERNANCE",
              "RECOMMENDATIONS_NEXT_ACTIONS",
              "APPENDIX"
            ]
          },
          "title": {"type": "string", "minLength": 1},
          "required": {"type": "boolean"},
          "content_ref": {"type": "string"},
          "summary": {"type": "string"},
          "validation_notes": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "rendered_report_source": {"type": "string", "minLength": 1},
    "pdf_intent": {"type": "boolean", "const": true}
  }
}
