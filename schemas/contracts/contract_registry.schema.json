{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/contracts/contract_registry.schema.json",
  "title": "VALOR Contract Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_id",
    "registry_version",
    "status",
    "owner",
    "review_branch",
    "purpose",
    "scope_categories",
    "side_effect_classes",
    "schema_defaults",
    "contracts",
    "non_callable_support_authorities",
    "cross_cutting_controls",
    "validation_requirements"
  ],
  "properties": {
    "registry_id": {
      "type": "string",
      "const": "VALOR-contract-registry"
    },
    "registry_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "const": "Orchestration"
    },
    "review_branch": {
      "type": "string",
      "minLength": 1
    },
    "created_date": {
      "type": "string"
    },
    "last_updated": {
      "type": "string"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "freeze_rule": {
      "type": "object",
      "additionalProperties": true
    },
    "scope_categories": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "public_user_callable",
        "internal_service_resolver",
        "non_callable_governed_support_authority",
        "policy_first_cross_cutting_control"
      ],
      "properties": {
        "public_user_callable": {
          "type": "array",
          "items": {"type": "string"}
        },
        "public_user_callable_policy_extension": {
          "type": "array",
          "items": {"type": "string"}
        },
        "internal_service_resolver": {
          "type": "array",
          "items": {"type": "string"}
        },
        "non_callable_governed_support_authority": {
          "type": "array",
          "items": {"type": "string"}
        },
        "policy_first_cross_cutting_control": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "side_effect_classes": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "READ_ONLY",
          "VALIDATE_ONLY",
          "STAGE_ONLY",
          "MUTATES_TRUTH",
          "GENERATES_ARTIFACT"
        ]
      }
    },
    "schema_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_schema",
        "response_schema"
      ],
      "properties": {
        "request_schema": {
          "type": "string",
          "const": "schemas/contracts/contract_request.schema.json"
        },
        "response_schema": {
          "type": "string",
          "const": "schemas/contracts/contract_response.schema.json"
        }
      }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "contract_id",
          "category",
          "owner",
          "file",
          "status",
          "actions"
        ],
        "properties": {
          "contract_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "PUBLIC_USER_CALLABLE",
              "PUBLIC_USER_CALLABLE_POLICY_EXTENSION",
              "PUBLIC_USER_CALLABLE_WHEN_DIRECT_KS_REQUEST",
              "INTERNAL_SERVICE_RESOLVER"
            ]
          },
          "owner": {
            "type": "string",
            "enum": ["WP", "PLAN", "DOC", "RPT", "KS", "PS"]
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type",
                "side_effect",
                "confirm",
                "schema",
                "status"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "aliases": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "internal_aliases": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "side_effect": {
                  "type": "string",
                  "enum": [
                    "READ_ONLY",
                    "VALIDATE_ONLY",
                    "STAGE_ONLY",
                    "MUTATES_TRUTH",
                    "GENERATES_ARTIFACT"
                  ]
                },
                "confirm": {
                  "type": "boolean"
                },
                "schema": {
                  "type": "string",
                  "minLength": 1
                },
                "block": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "status": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "non_callable_support_authorities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "authority_id",
          "owner",
          "status",
          "consumed_by"
        ]
      }
    },
    "cross_cutting_controls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "control_id",
          "category",
          "status",
          "callable_contract_required"
        ]
      }
    },
    "freeze_blockers_retained": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
