{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/objects/task_schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": true,
  "required": ["task_id", "wp_id", "name", "task_type", "phase", "status", "dependencies", "owner_role"],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "wp_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "task_type": {"type": "string", "enum": ["AUTHORING", "REVIEW", "APPROVAL", "EXECUTION", "REPORTING", "VENDOR_WAIT", "PROCUREMENT_WAIT", "LEAD_TIME"]},
    "phase": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["STAGED", "COMMITTED", "IN_PROGRESS", "DONE", "BLOCKED", "CANCELLED", "INCOMPLETE"]},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "dependency_edges": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "duration_ref": {"type": ["object", "null"], "additionalProperties": true},
    "planned_duration": {"type": ["object", "null"], "additionalProperties": true},
    "owner_role": {"type": "string", "minLength": 1},
    "proposed_start_date": {"type": ["string", "null"]},
    "proposed_finish_date": {"type": ["string", "null"]},
    "committed_start_date": {"type": ["string", "null"]},
    "committed_finish_date": {"type": ["string", "null"]},
    "provenance_refs": {"type": "object", "additionalProperties": true}
  }
}
