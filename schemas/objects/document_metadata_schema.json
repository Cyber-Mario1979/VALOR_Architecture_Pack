{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/objects/document_metadata_schema.json",
  "title": "Document Metadata Schema",
  "type": "object",
  "additionalProperties": true,
  "required": ["doc_id", "doc_type", "doc_version", "wp_id", "state", "template_ref", "bundle_ref", "citation_set", "source_chain_provenance", "source_input_completion_status", "provenance_stamps", "testing_only", "generated_at_utc"],
  "properties": {
    "doc_id": {"type": "string", "minLength": 1},
    "doc_type": {"type": "string", "enum": ["DCF", "VMP", "URS", "RA", "RTM", "DQ", "IQ", "OQ", "PQ", "VSR", "REPORT"]},
    "doc_version": {"type": "string", "minLength": 1},
    "version": {"type": "string"},
    "wp_id": {"type": "string", "minLength": 1},
    "state": {"type": "string", "enum": ["DRAFT", "FINAL", "INCOMPLETE", "BLOCKED", "PRODUCT_TESTING_ONLY"]},
    "generated_at_utc": {"type": "string", "format": "date-time"},
    "template_ref": {"type": "object", "additionalProperties": true, "required": ["template_id", "template_version"]},
    "bundle_ref": {"type": "object", "additionalProperties": true, "required": ["bundle_id", "bundle_version", "usage_classification"]},
    "citation_set": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "source_chain_provenance": {"type": "object", "additionalProperties": true, "minProperties": 1},
    "source_input_completion_status": {"type": "string", "enum": ["COMPLETE", "INCOMPLETE", "BLOCKED"]},
    "provenance_stamps": {"type": "object", "additionalProperties": true, "minProperties": 1},
    "testing_only": {"type": "boolean"},
    "testing_only_stamp_required": {"type": "boolean"},
    "testing_only_stamp": {"type": "string"},
    "usage_classification": {"type": "string", "enum": ["PRODUCT_TESTING_ONLY", "REGULATED_USE_BLOCKED"]},
    "regulated_output_allowed": {"type": "boolean"},
    "dcf_ref": {"type": ["object", "null"], "additionalProperties": true},
    "source_input_set_ref": {"type": ["object", "null"], "additionalProperties": true},
    "checksum": {"type": ["string", "null"]},
    "validation_summary": {"type": "object", "additionalProperties": true}
  }
}
