{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/objects/work_package_schema.json",
  "title": "Work Package",
  "type": "object",
  "additionalProperties": true,
  "required": ["wp_id", "title", "scope", "wp_type", "complexity", "lifecycle_state", "owner_function", "tasks", "provenance_refs"],
  "properties": {
    "wp_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "minLength": 1},
    "wp_type": {"type": "string", "minLength": 1},
    "complexity": {"type": "string", "minLength": 1},
    "lifecycle_state": {"type": "string", "enum": ["WP_DRAFT", "WP_STAGED", "WP_COMMITTED", "WP_IN_EXECUTION", "WP_CLOSED", "BLOCKED", "INCOMPLETE"]},
    "owner_function": {"type": "string", "minLength": 1},
    "created_at_utc": {"type": "string", "format": "date-time"},
    "updated_at_utc": {"type": "string", "format": "date-time"},
    "preset_ref": {"type": ["object", "null"], "additionalProperties": true},
    "task_pool_ref": {"type": ["object", "null"], "additionalProperties": true},
    "profile_ref": {"type": ["object", "null"], "additionalProperties": true},
    "calendar_logic_ref": {"type": ["object", "null"], "additionalProperties": true},
    "standards_bundle_ref": {"type": ["object", "null"], "additionalProperties": true},
    "provenance_refs": {"type": "object", "additionalProperties": true},
    "tasks": {"type": "array", "items": {"$ref": "task_schema.json"}},
    "planning_basis": {"type": "string"},
    "testing_only": {"type": "boolean"},
    "usage_classification": {"type": "string"}
  }
}
