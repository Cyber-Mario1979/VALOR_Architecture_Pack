{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/objects/confirmation_record_schema.json",
  "title": "VALOR Confirmation Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["confirmation_id", "confirmer_role", "timestamp_utc", "scope", "reference", "confirmed"],
  "properties": {
    "confirmation_id": {"type": "string", "minLength": 1},
    "confirmer_role": {"type": "string", "minLength": 1},
    "confirmer_name": {"type": "string"},
    "timestamp_utc": {"type": "string", "format": "date-time"},
    "scope": {"type": "string", "enum": ["COMMIT_STAGED_TASKS", "APPLY_PLAN", "FINALIZE_DOC", "GENERATE_EXPORT", "CLOSE_WP", "OVERRIDE_ACCEPTANCE"]},
    "reference": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ref_type", "ref_id"],
      "properties": {
        "ref_type": {"type": "string", "minLength": 1},
        "ref_id": {"type": "string", "minLength": 1},
        "ref_hash": {"type": "string"}
      }
    },
    "confirmed": {"type": "boolean"},
    "rationale": {"type": "string"}
  }
}
