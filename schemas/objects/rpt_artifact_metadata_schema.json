{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "valor://schemas/objects/rpt_artifact_metadata_schema.json",
  "title": "VALOR RPT Artifact Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "artifact_label",
    "target_scope",
    "wp_ids",
    "source_snapshot_hash",
    "template_id",
    "template_version",
    "contract_id",
    "contract_version",
    "action_type",
    "generated_at_utc",
    "projection_only",
    "mutates_wp_truth",
    "stamps",
    "validation_result",
    "content_ref"
  ],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_type": {
      "type": "string",
      "enum": ["WORK_PACKAGE_STATUS_REPORT", "WORK_PACKAGE_WORKBOOK_EXPORT", "WORK_PACKAGE_GANTT_CHART"]
    },
    "artifact_label": {"type": "string", "minLength": 1},
    "target_scope": {"type": "string", "enum": ["SINGLE_WP", "SELECTED_WP_SET"]},
    "wp_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "source_snapshot_hash": {"type": "string", "minLength": 1},
    "template_id": {"type": "string", "minLength": 1},
    "template_version": {"type": "string", "minLength": 1},
    "contract_id": {"type": "string", "const": "VALOR-contract-orch-rpt"},
    "contract_version": {"type": "string", "minLength": 1},
    "action_type": {
      "type": "string",
      "enum": [
        "RPT_GENERATE_STATUS_REPORT",
        "RPT_GENERATE_WORKBOOK_EXPORT",
        "RPT_GENERATE_GANTT_CHART",
        "RPT_LIST_ARTIFACTS",
        "RPT_GET_ARTIFACT"
      ]
    },
    "generated_at_utc": {"type": "string", "format": "date-time"},
    "projection_only": {"type": "boolean", "const": true},
    "mutates_wp_truth": {"type": "boolean", "const": false},
    "stamps": {"type": "object", "additionalProperties": true},
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "mode", "errors", "warnings"],
      "properties": {
        "ok": {"type": "boolean"},
        "mode": {"type": "string", "enum": ["STRICT"]},
        "errors": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
        "warnings": {"type": "array", "items": {"type": "object", "additionalProperties": true}}
      }
    },
    "content_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_type", "format", "uri"],
      "properties": {
        "ref_type": {"type": "string", "enum": ["FILE", "ARTIFACT_STORE_REF", "CONTENT_REF"]},
        "format": {"type": "string", "enum": ["PDF", "REPORT_SOURCE", "XLSX"]},
        "uri": {"type": "string", "minLength": 1}
      }
    }
  }
}
